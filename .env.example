# ============================================================================
# SharePoint AI Agent - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control!

# ──────────────────────────────────────────────────────────────────────────
# AI Provider Configuration
# ──────────────────────────────────────────────────────────────────────────
# Supported providers: 'gemini', 'vertexai', or 'openai' (for Groq/Ollama)
AI_PROVIDER=gemini

# ── Gemini Configuration ──────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Vertex AI Configuration (Google Cloud) ───────────────────────────────
# VERTEXAI_PROJECT_ID=your_gcp_project_id
# VERTEXAI_LOCATION=us-central1
# VERTEXAI_MODEL=gemini-2.5-flash
# VERTEXAI_CLIENT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# VERTEXAI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── OpenAI-Compatible Configuration (Groq, Ollama, etc.) ─────────────────
# OPENAI_API_KEY=your_openai_api_key_or_groq_key
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama3-8b-8192

# ──────────────────────────────────────────────────────────────────────────
# Microsoft 365 / SharePoint Configuration
# ──────────────────────────────────────────────────────────────────────────
TENANT_ID=your_microsoft_tenant_id
CLIENT_ID=your_azure_app_client_id
CLIENT_SECRET=your_azure_app_client_secret
SITE_ID=your_sharepoint_site_id
# APP_CATALOG_SITE_ID=


# ──────────────────────────────────────────────────────────────────────────
# Security & Authentication
# ──────────────────────────────────────────────────────────────────────────
# Production deployment always uses Azure AD JWT validation
# API Key authentication has been fully removed — only AAD tokens accepted

# ──────────────────────────────────────────────────────────────────────────
# Redis Configuration (Optional - for persistent conversation state)
# ──────────────────────────────────────────────────────────────────────────
# Redis URL for conversation state persistence
# If not enabled, conversation state will be kept in-memory (lost on restart)
REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────────────────────────────────────
# CORS — Tenant Allowlist (Recommended for production)
# ──────────────────────────────────────────────────────────────────────────
# Comma-separated SharePoint tenant names for strict CORS validation.
# Example: "optimumpartnersjo,contoso"
# Only https://<tenant>.sharepoint.com origins will be allowed.
# Leave empty to allow all *.sharepoint.com subdomains (less secure).
ALLOWED_SHAREPOINT_TENANTS=

# ──────────────────────────────────────────────────────────────────────────
# OBO Token Cache TTL (seconds, default: 900 = 15 minutes)
# ──────────────────────────────────────────────────────────────────────────
OBO_CACHE_TTL_SECONDS=900

# ──────────────────────────────────────────────────────────────────────────
# CORS & Network Configuration
# ──────────────────────────────────────────────────────────────────────────
# Environment: development, staging, or production
ENVIRONMENT=development

# Comma-separated list of allowed origins for CORS
# Default: localhost ports for development
# Production: Restrict to your SharePoint domain(s) ONLY
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4321,http://localhost:8000

# Production example (uncomment and modify):
# ALLOWED_ORIGINS=https://yourcompany.sharepoint.com,https://yourcompany-admin.sharepoint.com

# ──────────────────────────────────────────────────────────────────────────
# Application Configuration (Optional Overrides)
# ──────────────────────────────────────────────────────────────────────────
# Port for local development (default: 8000)
# PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

